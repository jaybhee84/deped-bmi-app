{
  "name": "deped-bmi-app",
  "private": true,
  "version": "1.1.0",
  "description": "A desktop application for managing and monitoring Body Mass Index (BMI) records for DepEd personnel.",
  "author": "BuzzJay",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
   
    "postinstall": "electron-builder install-app-deps",
    "lint": "oxlint",
    "preview": "vite preview",
    "electron": "electron .",
    "dev:electron": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "dist": "npm run build && electron-builder",
    "release": "npm run build && electron-builder"
  
  },
  "build": {
    "appId": "com.deped.bmiapp",
    "productName": "DepEd BMI App",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "asar": true,
    "generateUpdatesFilesForAllChannels": true,

   
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "publish": {
      "provider": "github",
      "owner": "jaybhee84",
      "repo": "deped-bmi-app",
      "releaseType": "release"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.ico"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.utilities",
      "icon": "public/icon.icns"
    },
    "dmg": {
      "sign": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  
  },  
  "dependencies": {
    "@supabase/supabase-js": "^2.110.1",
    "better-sqlite3": "^12.11.1",
    "electron-updater": "^6.3.9",
    "exceljs": "^4.4.0",
    "file-saver": "^2.0.5",
    "papaparse": "^5.5.4",
    "pdf-lib": "^1.17.1",
    "pdf-to-printer": "^5.8.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-easy-crop": "^6.0.2"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.2.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "oxlint": "^1.69.0",
    "prettier": "^3.9.1",
    "vite": "^8.1.0",
    "wait-on": "^9.0.10"
  }
}